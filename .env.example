# ---------- Database ----------
# Neon (recommended) — grab the pooled connection string from Vercel → Storage → Neon
# Format: postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/bakery?sslmode=require"

# ---------- Admin ----------
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-strong-password"

# Long random string. Generate: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"

# ---------- Image uploads ----------
# Vercel Blob token (auto-injected on Vercel when you connect a Blob store)
# Leave blank for local dev — uploads fall back to public/uploads/
# BLOB_READ_WRITE_TOKEN=""

# ---------- Notifications (optional stubs) ----------
# Wire these up in lib/notify.ts when you have credentials
# RESEND_API_KEY=""
# NOTIFY_EMAIL_TO=""
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""
